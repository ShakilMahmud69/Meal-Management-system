{
  "name": "meal-management-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "scripts": {
    "bootstrap": "npm install --workspaces",
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
    "backend": "npm --workspace backend run dev",
    "frontend": "npm --workspace frontend run dev"
  }
}
